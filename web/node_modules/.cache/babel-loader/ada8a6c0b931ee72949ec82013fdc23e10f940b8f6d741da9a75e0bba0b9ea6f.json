\\u043D\\u0430 \\u0432\\u0430\\u0448 email\"})]}),/*#__PURE__*/_jsxs(\"div\",{className:\"card\",children:[/*#__PURE__*/_jsx(\"h3\",{style:{marginTop:'0'},children:\"\\u0412\\u044B\\u0441\\u043E\\u043A\\u043E\\u0435 \\u043A\\u0430\\u0447\\u0435\\u0441\\u0442\\u0432\\u043E\"}),/*#__PURE__*/_jsx(\"p\",{children:\"\\u0412\\u0441\\u0435 \\u0444\\u043E\\u0442\\u043E\\u0433\\u0440\\u0430\\u0444\\u0438\\u0438 \\u0432\\u044B\\u043F\\u043E\\u043B\\u043D\\u0435\\u043D\\u044B \\u0432 \\u043E\\u0442\\u043B\\u0438\\u0447\\u043D\\u043E\\u043C \\u043A\\u0430\\u0447\\u0435\\u0441\\u0442\\u0432\\u0435 \\u0438 \\u043E\\u0442\\u043E\\u0431\\u0440\\u0430\\u0436\\u0430\\u044E\\u0442 \\u0441\\u0443\\u0449\\u043D\\u043E\\u0441\\u0442\\u044C \\u043A\\u0430\\u0436\\u0434\\u043E\\u0433\\u043E \\u0444\\u0440\\u0435\\u0439\\u043C\\u0432\\u043E\\u0440\\u043A\\u0430\"})]})]})]});};export default Home;","map":{"version":3,"names":["React","useNavigate","jsx","_jsx","jsxs","_jsxs","Home","navigate","style","textAlign","padding","children","maxWidth","margin","backgroundColor","borderRadius","boxShadow","fontSize","color","marginBottom","lineHeight","display","justifyContent","gap","onClick","gridTemplateColumns","className","marginTop"],"sources":["/Users/sindi_hall/Desktop/PROGRAMMING/E-Commerce_2/E-Commerce/web/src/components/Home.jsx"],"sourcesContent":["import React from 'react';\nimport { useNavigate } from 'react-router-dom';\n\nconst Home = () => {\n  const navigate = useNavigate();\n\n  return (\n    <div style={{ textAlign: 'center', padding: '40px 20px' }}>\n      <div style={{ \n        maxWidth: '800px', \n        margin: '0 auto',\n        backgroundColor: 'white',\n        borderRadius: '12px',\n        padding: '40px',\n        boxShadow: '0 4px 12px rgba(0, 0, 0, 0.05)'\n      }}>\n        <h1 style={{ \n          fontSize: '36px', \n          color: 'var(--text-color)',\n          marginBottom: '20px'\n        }}>\n          FrameStore\n        </h1>\n        \n        <p style={{ \n          fontSize: '18px', \n          lineHeight: '1.6',\n          color: 'var(--light-text)',\n          marginBottom: '30px'\n        }}>\n          Добро пожаловать в наш магазин фреймворков для программирования! \n          Мы предлагаем уникальные фотографии популярных фреймворков, \n          которые будут отправлены на ваш email после покупки.\n        </p>\n        \n        <div style={{ display: 'flex', justifyContent: 'center', gap: '20px' }}>\n          <button \n            onClick={() => navigate('/products')} \n            style={{ \n              padding: '12px 30px', \n              fontSize: '18px' \n            }}\n          >\n            Смотреть фреймворки\n          </button>\n          \n          <button \n            onClick={() => navigate('/login')} \n            style={{ \n              backgroundColor: 'var(--secondary-bg)', \n              color: 'var(--text-color)' \n            }}\n          >\n            Войти в аккаунт\n          </button>\n        </div>\n      </div>\n      \n      <div style={{ \n        display: 'grid',\n        gridTemplateColumns: 'repeat(auto-fit, minmax(280px, 1fr))',\n        gap: '30px',\n        margin: '40px auto',\n        maxWidth: '1000px'\n      }}>\n        <div className=\"card\">\n          <h3 style={{ marginTop: '0' }}>Большой выбор</h3>\n          <p>Мы предлагаем фотографии самых популярных фреймворков для различных языков программирования</p>\n        </div>\n        \n        <div className=\"card\">\n          <h3 style={{ marginTop: '0' }}>Мгновенная доставка</h3>\n          <p>После оформления заказа фотографии сразу отправляются на ваш email</p>\n        </div>\n        \n        <div className=\"card\">\n          <h3 style={{ marginTop: '0' }}>Высокое качество</h3>\n          <p>Все фотографии выполнены в отличном качестве и отображают сущность каждого фреймворка</p>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default Home;"],"mappings":"AAAA,MAAO,CAAAA,KAAK,K